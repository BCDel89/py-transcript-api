# ─────────────────────────────────────────────────────────────
# py-transcript-api — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this to .env for local development.
# For staging/production, inject these via Doppler or Coolify.
# DO NOT commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Webshare Proxy (Option A — direct, preferred for staging/local) ──
# Set these to bypass AWS Secrets Manager entirely.
WEBSHARE_USERNAME=your_webshare_proxy_username
WEBSHARE_PASSWORD=your_webshare_proxy_password

# ── Webshare Proxy (Option B — AWS Secrets Manager, used in production) ──
# Leave WEBSHARE_USERNAME/PASSWORD unset and provide these instead.
# The app will fetch credentials from the named secret automatically.
# AWS_REGION=us-east-1
# WEBSHARE_SECRET_NAME=WebshareSecret727A6F68-PWHxTNDvdAaV
# AWS_ACCESS_KEY_ID=     # only needed if not using IAM instance role
# AWS_SECRET_ACCESS_KEY= # only needed if not using IAM instance role

# ── Server ──
PORT=8000
